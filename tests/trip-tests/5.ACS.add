#!/bin/bash

#F=_generated/CompositeLexers/LexerDelegatorInvokesDelegateRule/json.log
F=_generated/FullContextParsing/AmbiguityNoLoop/json.log
#F=_generated/LexerExec/GreedyClosure/json.log
#F=_generated/LexerExec/ActionPlacement/json.log
#F=_generated/LexerExec/RecursiveLexerRuleRefWithWildcardPlus_1/json.log
#F=_generated/LexerExec/ZeroLengthToken/json.log

echo $F

ATNARGS=""
DIR=`dirname $F`
if [ -r $DIR/Lexer.interp ]; then ATNARGS+=" --lexer-atn $DIR/Lexer.interp"; fi
if [ -r $DIR/Parser.interp ]; then ATNARGS+=" --parser-atn $DIR/Parser.interp"; fi


ARGS=" -e ATNConfigSet.add"
#NARGS="-n 1"
./replay_test.opt entry-exit $ARGS $F | jq -s 'length | "\(.) lines (full entry/exit)"'
./replay_test.opt entry-exit --ooe $ARGS $F | jq -s 'length | "\(.) lines (only entry)"'
./replay_test.opt entry-exit $NARGS $ARGS $F | jq -S . > _generated/1.log
./replay_test.opt simulate $NARGS $ATNARGS --ooe $ARGS $F | jq -S . > _generated/2.log

diff -Bwiu _generated/1.log _generated/2.log
