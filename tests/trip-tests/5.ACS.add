#!/bin/bash

#F=_build/CompositeLexers/LexerDelegatorInvokesDelegateRule/json.log
#F=_build/FullContextParsing/AmbiguityNoLoop/json.log
#F=_build/LexerExec/GreedyClosure/json.log
#F=_build/LexerExec/ActionPlacement/json.log
#F=_build/LexerExec/RecursiveLexerRuleRefWithWildcardPlus_1/json.log
F=_build/LexerExec/ZeroLengthToken/json.log
echo $F

ATNARGS=""
DIR=`dirname $F`
if [ -r $DIR/Lexer.interp ]; then ATNARGS+=" --lexer-atn $DIR/Lexer.interp"; fi
if [ -r $DIR/Parser.interp ]; then ATNARGS+=" --parser-atn $DIR/Parser.interp"; fi


ARGS=" -e ATNConfigSet.add"
#NARGS="-n 1"
./jsonlog_util.opt entry-exit $ARGS $F | jq -s 'length | "\(.) lines (full entry/exit)"'
./jsonlog_util.opt entry-exit --ooe $ARGS $F | jq -s 'length | "\(.) lines (only entry)"'
./jsonlog_util.opt entry-exit $NARGS $ARGS $F | jq -S . > _build/1.log
./jsonlog_util.opt simulate $NARGS $ATNARGS --ooe $ARGS $F | jq -S . > _build/2.log

diff -Bwiu _build/1.log _build/2.log
