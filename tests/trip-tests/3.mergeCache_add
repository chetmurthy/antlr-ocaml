#!/bin/bash

set -e

for f in _generated/*/*/json.log
do
    echo $f
ATNARGS=""
DIR=`dirname $f`
if [ -r $DIR/Lexer.interp ]; then ATNARGS+=" --lexer-atn $DIR/Lexer.interp"; fi
if [ -r $DIR/Parser.interp ]; then ATNARGS+=" --parser-atn $DIR/Parser.interp"; fi

    ./replay_test.opt entry-exit -e "mergeCache_add" $f | jq -s 'length | "\(.) lines"'
    diff -Bwiu <( ./replay_test.opt entry-exit -e "mergeCache_add" $f | jq . ) <( ./replay_test.opt entrypoints $ATNARGS --ooe -e "mergeCache_add" $f | jq . )
done




