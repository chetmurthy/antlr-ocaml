#!/bin/bash

set -e

ARGS=" -e ATNConfigSet.add"

for f in _build/*/*/json.log
do
    echo $f

ATNARGS=""
DIR=`dirname $f`
if [ -r $DIR/Lexer.interp ]; then ATNARGS+=" --lexer-atn $DIR/Lexer.interp"; fi
if [ -r $DIR/Parser.interp ]; then ATNARGS+=" --parser-atn $DIR/Parser.interp"; fi


    ./jsonlog_util.opt entry-exit $ARGS $f | jq -s 'length | "\(.) lines"'
    diff -Bwiu <( ./jsonlog_util.opt entry-exit $ARGS $f | jq -S . ) <( ./jsonlog_util.opt simulate $ATNARGS --ooe $ARGS $f | jq -S . )
done




