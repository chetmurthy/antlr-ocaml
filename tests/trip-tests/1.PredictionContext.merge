#!/bin/bash

set -e

for f in _build/*/*/json.log
do
    echo $f
    ./jsonlog_util.opt entry-exit -e "PredictionContext.merge" $f | jq -s 'length | "\(.) lines"'
    diff -Bwiu <( ./jsonlog_util.opt entry-exit -e "PredictionContext.merge" $f | jq . ) <( ./jsonlog_util.opt simulate --ooe -e "PredictionContext.merge" $f | jq . )
done




