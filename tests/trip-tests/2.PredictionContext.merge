#!/bin/bash

#F=_build/FullContextParsing/AmbiguityNoLoop/json.log
F=_build/FullContextParsing/ExprAmbiguity_2/json.log
echo $F

ARGS=" -e PredictionContext.merge"

./jsonlog_util.opt entry-exit $ARGS $F | jq -s 'length | "\(.) lines (full entry/exit)"'
./jsonlog_util.opt entry-exit --ooe $ARGS $F | jq -s 'length | "\(.) lines (only entry)"'

./jsonlog_util.opt entry-exit $ARGS $F | jq . > _build/1.log

ATNARGS=""
DIR=`dirname $F`
if [ -r $DIR/Lexer.interp ]; then ATNARGS+=" --lexer-atn $DIR/Lexer.interp"; fi
if [ -r $DIR/Parser.interp ]; then ATNARGS+=" --parser-atn $DIR/Parser.interp"; fi

./jsonlog_util.opt simulate $ATNARGS --ooe $ARGS $F | jq . > _build/2.log

diff -Bwiu _build/1.log _build/2.log
