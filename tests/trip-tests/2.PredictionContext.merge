#!/bin/bash

#F=_build/FullContextParsing/AmbiguityNoLoop/json.log
F=_build/FullContextParsing/ExprAmbiguity_2/json.log
echo $F

./jsonlog_util.opt entry-exit -e "PredictionContext.merge" $F | jq -s 'length | "\(.) lines (full entry/exit)"'
./jsonlog_util.opt entry-exit --ooe -e "PredictionContext.merge" $F | jq -s 'length | "\(.) lines (only entry)"'

./jsonlog_util.opt entry-exit -e "PredictionContext.merge" $F | jq . > _build/1.log
./jsonlog_util.opt simulate --ooe -e "PredictionContext.merge" $F | jq . > _build/2.log

diff -Bwiu _build/1.log _build/2.log
