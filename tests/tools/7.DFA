#!/bin/bash

F=_generated/LexerExec/CharSet/json.log

echo $F

ATNARGS=""
DIR=`dirname $F`
if [ -r $DIR/Lexer.interp ]; then ATNARGS+=" --lexer-atn $DIR/Lexer.interp"; fi
if [ -r $DIR/Parser.interp ]; then ATNARGS+=" --parser-atn $DIR/Parser.interp"; fi


ARGS=""
source tools/ACS.entrypoints.sh
source tools/DFA.entrypoints.sh

#NARGS=" --stop-nth 1"

rm -f _generated/*.log

./replay_test.opt deserialize $F

./replay_test.opt entry-exit $ARGS $F | jq -s 'length | "\(.) lines (full entry/exit)"'
./replay_test.opt entry-exit --ooe $ARGS $F | jq -s 'length | "\(.) lines (only entry)"'

./replay_test.opt entry-exit $ARGS $F | jq -S . > _generated/ee.log
./replay_test.opt entry-exit --ooe $ARGS $F | jq -S . > _generated/ooe.log

./replay_test.opt entry-exit $NARGS $ARGS $F | jq -S . > _generated/1.log
./replay_test.opt entry-exit $NARGS --ooe $ARGS $F | jq -S . > _generated/2in.log
./replay_test.opt acs $NARGS $ATNARGS --ooe $ARGS $F | jq -S . > _generated/2out.log

diff -Bwiu _generated/1.log _generated/2out.log
